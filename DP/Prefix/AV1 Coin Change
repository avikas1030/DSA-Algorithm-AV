#include <bits/stdc++.h>
using namespace std;
 
int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
 
    int n, W;
    cin >> n >> W;
 
    vector<int> w(n + 1);
    for (int i = 1; i <= n; i++) {
        cin >> w[i]; 
    }
 
    const int INF = 1e9;
    vector<int> dp(W + 1, INF);
 
    dp[0] = 0; // base case
 
    for (int i = 1; i <= n; i++) {
        for (int j = w[i]; j <= W; j++) {
            dp[j] = min(dp[j], dp[j - w[i]] + 1);
        }
    }
 
    if (dp[W] == INF)
        cout << -1 << '\n';
    else
        cout << dp[W] << '\n';
 
    return 0;
}
